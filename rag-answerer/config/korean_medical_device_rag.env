# Upstream retrieval profile for rag-answerer.
# rag-answerer itself is the grounded answer generator.
# These settings are for the retriever/reranker layer that prepares context before calling gemma4-rag.

RAG_PROFILE_NAME=korean-medical-device
RAG_LOCALE=ko-KR
RAG_DOMAIN=medical-device

# Retriever models
RAG_EMBEDDING_MODEL=mykor/KURE-v1
RAG_EMBEDDING_MAX_TOKENS=8192
RAG_SPARSE_RETRIEVER=bm25
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Retrieval strategy
RAG_RETRIEVAL_MODE=hybrid
RAG_FUSION_METHOD=rrf
RAG_DENSE_TOP_K=12
RAG_SPARSE_TOP_K=20
RAG_FUSED_TOP_K=8
RAG_FINAL_TOP_K=5

# Chunking guidance for Korean manuals, IFUs, SOPs, and service notes
RAG_CHUNK_SIZE_TOKENS=700
RAG_CHUNK_OVERLAP_TOKENS=120
RAG_KEEP_SECTION_PATH=1
RAG_KEEP_TABLE_ROWS=1
RAG_KEEP_WARNING_BLOCKS_INTACT=1

# Safety-oriented retrieval hints
RAG_PRESERVE_DEVICE_CODES=1
RAG_PRESERVE_UNITS=1
RAG_REQUIRE_CHUNK_IDS=1
RAG_REQUIRE_SOURCE_METADATA=1
RAG_REQUIRE_HUMAN_REVIEW_ON_CONFLICT=1
RAG_REQUIRE_HUMAN_REVIEW_ON_LOW_EVIDENCE=1

# Hand-off formatting guidance
RAG_CONTEXT_FORMAT=chunked_text_with_metadata
RAG_CONTEXT_METADATA_FIELDS=chunk_id,source,section,page,score
